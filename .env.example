# Copy this file to .env and fill in real values. NEVER commit .env itself.

# Lightning AI key — used by ai_service.py and chat_service.py.
# Get one at https://lightning.ai/ — required for AI diagnosis + chatbot.
LIGHTNING_API_KEY=

# Telegram bot token from @BotFather. Optional — only needed if you run `uv run manage.py runbot`.
TELEGRAM_BOT_TOKEN=
